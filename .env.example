# =====================================================================
# COPY THIS FILE TO ".env" FOR LOCAL DEVELOPMENT (and fill in real values).
# NEVER commit your actual ".env" file to GitHub - it holds secrets!
# On Railway, you enter these same names/values in the dashboard instead
# of using this file (see README section F).
# =====================================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=women_safety_db
DB_USER=root
DB_PASSWORD=your_local_mysql_password

# --- JWT ---
JWT_SECRET=please-change-this-to-a-long-random-string-at-least-32-chars

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- CORS ---
ALLOWED_ORIGINS=*

# --- Port (Railway sets this automatically, ignore locally) ---
PORT=8080
